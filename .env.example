# Database
DATABASE_URL=sqlite:///./dev.db

# JWT
SECRET_KEY=<generate with: python3 -c "import secrets; print(secrets.token_hex(32))">
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=https://<bucket>.r2.dev

# Admin
ADMIN_SECRET_KEY=<generate with: python3 -c "import secrets; print(secrets.token_hex(16))">

# App
ENVIRONMENT=development
PORT=8000
APP_BASE_URL=http://localhost:8000

# Google OAuth (선택 — 미설정 시 Google 로그인 비활성화)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Blink Lightning API (선택 — 미설정 시 수동 송금 모드)
# 설정 시 /rewards/claim 호출 즉시 자동 Lightning 송금
BLINK_API_KEY=

# Redis (선택 — 미설정 시 백엔드 직접 ffmpeg fallback 사용)
# merge-audio 잡 큐용
REDIS_URL=redis://localhost:6379/0
