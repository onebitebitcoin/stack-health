# ── 필수 ────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@localhost:5432/stack_health
SECRET_KEY=                        # openssl rand -hex 32
ADMIN_SECRET_KEY=                  # openssl rand -hex 16

# ── 앱 URL (자체 서버) ───────────────────────────────────
APP_URL=https://stackhealth.life
APP_BASE_URL=https://stackhealth.life
FRONTEND_URL=https://stackhealth.life

# ── Google OAuth ─────────────────────────────────────────
# Google Console → Authorized redirect URIs 에 아래 URL 등록 필수:
# https://stackhealth.life/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Cloudflare R2 ────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# ── 선택 ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
BLINK_API_KEY=
ENVIRONMENT=production
PORT=8000
ACCESS_TOKEN_EXPIRE_MINUTES=10080
